{
  "name": "mongoose-hyper-cache",
  "version": "1.0.0",
  "description": "High-performance Mongoose caching layer with memory/Redis providers and synchronous reads",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/build-mjs.js",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mongoose",
    "cache",
    "redis",
    "performance",
    "mongodb",
    "in-memory"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lru-cache": "^10.4.3",
    "mongoose": "^9.6.2",
    "redis": "^4.7.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/express": "^5.0.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
